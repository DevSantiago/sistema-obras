generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model prueba_conexion {
  id        String   @id @default(uuid())
  mensaje   String
  creado_en DateTime @default(now())
}

model usuarios {
  id               String   @id @default(uuid())
  tipo_documento   String
  numero_documento String   @unique
  nombre           String
  correo           String   @unique
  telefono         String?
  password_hash    String?
  estado           String   @default("ACTIVO")
  creado_en        DateTime @default(now())
  actualizado_en   DateTime @updatedAt

  roles usuarios_roles[]

  proyectos_creados           proyectos_base[] @relation("ProyectosBaseCreadoPor")
  centros_iniciados_ejecucion centros_costo[]  @relation("CentrosCostoInicioEjecucionPor")
  fondos_creados              fondos[]         @relation("FondosCreadoPor")

  accesos_recibidos accesos_usuario_proyecto[] @relation("AccesosUsuario")
  accesos_asignados accesos_usuario_proyecto[] @relation("AccesosAsignadoPor")
  accesos_revocados accesos_usuario_proyecto[] @relation("AccesosRevocadoPor")

  beneficiarios_asociados beneficiarios_pago[] @relation("BeneficiarioUsuarioAsociado")

  solicitudes_creadas    solicitudes_pago[] @relation("SolicitudesCreadasPor")
  solicitudes_aprobadas1 solicitudes_pago[] @relation("SolicitudesAprobadas1Por")
  solicitudes_aprobadas2 solicitudes_pago[] @relation("SolicitudesAprobadas2Por")
  solicitudes_pagadas    solicitudes_pago[] @relation("SolicitudesPagadasPor")

  adjuntos_subidos adjuntos[] @relation("AdjuntosSubidosPor")
}

model roles {
  id             String   @id @default(uuid())
  nombre         String   @unique
  descripcion    String?
  activo         Boolean  @default(true)
  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt

  usuarios_roles usuarios_roles[]
  permisos       roles_permisos[]
  lineas_negocio roles_lineas_negocio[]
}

model usuarios_roles {
  id         String   @id @default(uuid())
  usuario_id String
  rol_id     String
  creado_en  DateTime @default(now())

  usuario usuarios @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  rol     roles    @relation(fields: [rol_id], references: [id])

  @@unique([usuario_id])
  @@index([rol_id])
}

model permisos {
  id             String   @id @default(uuid())
  codigo         String   @unique
  nombre         String
  descripcion    String?
  activo         Boolean  @default(true)
  creado_en      DateTime @default(now())
  actualizado_en DateTime @updatedAt

  roles roles_permisos[]
}

model roles_permisos {
  id         String   @id @default(uuid())
  rol_id     String
  permiso_id String
  creado_en  DateTime @default(now())

  rol     roles    @relation(fields: [rol_id], references: [id], onDelete: Cascade)
  permiso permisos @relation(fields: [permiso_id], references: [id], onDelete: Cascade)

  @@unique([rol_id, permiso_id])
  @@index([rol_id])
  @@index([permiso_id])
}

model roles_lineas_negocio {
  id            String   @id @default(uuid())
  rol_id        String
  linea_negocio String
  creado_en     DateTime @default(now())

  rol roles @relation(fields: [rol_id], references: [id], onDelete: Cascade)

  @@unique([rol_id, linea_negocio])
  @@index([rol_id])
  @@index([linea_negocio])
}

model proyectos_base {
  id              String   @id @default(uuid())
  nombre          String
  descripcion     String?
  estado_proyecto String   @default("EN_LICITACION")
  activo          Boolean  @default(true)
  creado_por      String?
  creado_en       DateTime @default(now())
  actualizado_en  DateTime @updatedAt

  creador                 usuarios?                  @relation("ProyectosBaseCreadoPor", fields: [creado_por], references: [id])
  centros_costo           centros_costo[]
  fondo                   fondos?
  accesos                 accesos_usuario_proyecto[]
  secuencias_documentales secuencias_documentales[]

  solicitudes_pago solicitudes_pago[]

  @@index([nombre])
  @@index([estado_proyecto])
  @@index([activo])
}

model centros_costo {
  id                                  String    @id @default(uuid())
  proyecto_base_id                    String
  linea_negocio                       String
  fase_centro_costo                   String
  prefijo                             String
  codigo                              String    @unique
  nombre                              String
  descripcion                         String?
  estado_centro_costo                 String    @default("EN_LICITACION")
  creado_directamente_en_ejecucion    Boolean   @default(false)
  motivo_creacion_ejecucion           String?
  fecha_inicio_ejecucion              DateTime?
  soporte_inicio_ejecucion_adjunto_id String?
  observacion_inicio_ejecucion        String?
  inicio_ejecucion_por                String?
  inicio_ejecucion_en                 DateTime?
  activo                              Boolean   @default(true)
  creado_en                           DateTime  @default(now())
  actualizado_en                      DateTime  @updatedAt

  proyecto_base            proyectos_base            @relation(fields: [proyecto_base_id], references: [id])
  usuario_inicio_ejecucion usuarios?                 @relation("CentrosCostoInicioEjecucionPor", fields: [inicio_ejecucion_por], references: [id])
  secuencias_documentales  secuencias_documentales[]

  solicitudes_pago solicitudes_pago[]

  @@unique([proyecto_base_id, linea_negocio, fase_centro_costo])
  @@index([proyecto_base_id])
  @@index([codigo])
  @@index([linea_negocio])
  @@index([fase_centro_costo])
  @@index([estado_centro_costo])
  @@index([activo])
}

model fondos {
  id               String   @id @default(uuid())
  proyecto_base_id String   @unique
  nombre           String
  descripcion      String?
  saldo_actual     Decimal  @default(0) @db.Decimal(14, 2)
  activo           Boolean  @default(true)
  creado_por       String?
  creado_en        DateTime @default(now())
  actualizado_en   DateTime @updatedAt

  proyecto_base proyectos_base @relation(fields: [proyecto_base_id], references: [id])
  creador       usuarios?      @relation("FondosCreadoPor", fields: [creado_por], references: [id])

  solicitudes_pago solicitudes_pago[]

  @@index([activo])
}

model accesos_usuario_proyecto {
  id               String    @id @default(uuid())
  usuario_id       String
  proyecto_base_id String
  linea_negocio    String
  activo           Boolean   @default(true)
  asignado_por     String?
  asignado_en      DateTime  @default(now())
  revocado_por     String?
  revocado_en      DateTime?
  creado_en        DateTime  @default(now())
  actualizado_en   DateTime  @updatedAt

  usuario       usuarios       @relation("AccesosUsuario", fields: [usuario_id], references: [id], onDelete: Cascade)
  proyecto_base proyectos_base @relation(fields: [proyecto_base_id], references: [id], onDelete: Cascade)
  asignador     usuarios?      @relation("AccesosAsignadoPor", fields: [asignado_por], references: [id])
  revocador     usuarios?      @relation("AccesosRevocadoPor", fields: [revocado_por], references: [id])

  @@unique([usuario_id, proyecto_base_id, linea_negocio])
  @@index([usuario_id])
  @@index([proyecto_base_id])
  @@index([linea_negocio])
  @@index([activo])
}

model proveedores {
  id                     String   @id @default(uuid())
  nombre                 String
  tipo_documento         String
  numero_documento       String
  correo                 String?
  telefono               String?
  direccion              String?
  banco                  String?
  tipo_cuenta_bancaria   String?
  numero_cuenta_bancaria String?
  activo                 Boolean  @default(true)
  creado_en              DateTime @default(now())
  actualizado_en         DateTime @updatedAt

  beneficiarios beneficiarios_pago[]

  solicitudes_pago solicitudes_pago[]

  @@index([tipo_documento, numero_documento])
  @@index([numero_documento])
  @@index([nombre])
  @@index([activo])
}

model beneficiarios_pago {
  id                     String   @id @default(uuid())
  tipo_beneficiario      String
  proveedor_id           String?
  usuario_id             String?
  nombre                 String
  tipo_documento         String?
  numero_documento       String?
  medio_pago_preferido   String?
  banco                  String?
  tipo_cuenta_bancaria   String?
  numero_cuenta_bancaria String?
  telefono               String?
  correo                 String?
  notas                  String?
  activo                 Boolean  @default(true)
  creado_en              DateTime @default(now())
  actualizado_en         DateTime @updatedAt

  proveedor        proveedores? @relation(fields: [proveedor_id], references: [id])
  usuario_asociado usuarios?    @relation("BeneficiarioUsuarioAsociado", fields: [usuario_id], references: [id])

  solicitudes_pago solicitudes_pago[]

  detalles_nomina detalles_nomina_solicitud[]

  @@unique([tipo_documento, numero_documento], map: "beneficiarios_pago_tipo_documento_numero_documento_key")
  @@index([tipo_beneficiario])
  @@index([usuario_id])
  @@index([proveedor_id])
  @@index([tipo_documento, numero_documento])
  @@index([medio_pago_preferido])
  @@index([activo])
}

model secuencias_documentales {
  id               String   @id @default(uuid())
  tipo_secuencia   String
  proyecto_base_id String?
  centro_costo_id  String?
  clave_contexto   String
  prefijo          String
  anio             Int
  valor_actual     Int      @default(0)
  creado_en        DateTime @default(now())
  actualizado_en   DateTime @updatedAt

  proyecto_base proyectos_base? @relation(fields: [proyecto_base_id], references: [id])
  centro_costo  centros_costo?  @relation(fields: [centro_costo_id], references: [id])

  @@unique([tipo_secuencia, clave_contexto, anio])
  @@index([proyecto_base_id])
  @@index([centro_costo_id])
  @@index([tipo_secuencia])
  @@index([clave_contexto])
}

model solicitudes_pago {
  id                        String    @id @default(uuid())
  numero_solicitud String? @unique @db.VarChar(100)
  tipo_solicitud            String    @default("PAGO_PROVEEDOR")
  modalidad_nomina          String?
  periodo_nomina            String?   @db.VarChar(7)
  proyecto_base_id          String
  fondo_id                  String
  centro_costo_id           String
  beneficiario_id           String?
  proveedor_id              String?
  categoria_gasto           String?
  categoria_reembolso       String?
  concepto_nomina           String?
  tipo_impuesto             String?
  periodo_impuesto          String?   @db.VarChar(7)
  medio_pago                String?
  adjunto_archivo_origen_id String?
  descripcion               String
  valor_bruto               Decimal   @db.Decimal(14, 2)
  valor_impuestos           Decimal   @default(0) @db.Decimal(14, 2)
  valor_retenciones         Decimal   @default(0) @db.Decimal(14, 2)
  valor_descuentos          Decimal   @default(0) @db.Decimal(14, 2)
  valor_neto                Decimal   @db.Decimal(14, 2)
  valor_pagado              Decimal?  @db.Decimal(14, 2)
  valor_reservado           Decimal?  @db.Decimal(14, 2)
  estado_actual             String    @default("BORRADOR")
  creado_por                String?
  aprobado_1_por            String?
  aprobado_2_por            String?
  pagado_por                String?
  enviado_en                DateTime?
  aprobado_1_en             DateTime?
  aprobado_2_en             DateTime?
  devuelto_aprobador_1_en   DateTime?
  devuelto_solicitante_en   DateTime?
  pagado_en                 DateTime?
  creado_en                 DateTime  @default(now())
  actualizado_en            DateTime  @updatedAt

  proyecto_base proyectos_base      @relation(fields: [proyecto_base_id], references: [id])
  fondo         fondos              @relation(fields: [fondo_id], references: [id])
  centro_costo  centros_costo       @relation(fields: [centro_costo_id], references: [id])
  beneficiario  beneficiarios_pago? @relation(fields: [beneficiario_id], references: [id])
  proveedor     proveedores?        @relation(fields: [proveedor_id], references: [id])

  creador    usuarios? @relation("SolicitudesCreadasPor", fields: [creado_por], references: [id])
  aprobador1 usuarios? @relation("SolicitudesAprobadas1Por", fields: [aprobado_1_por], references: [id])
  aprobador2 usuarios? @relation("SolicitudesAprobadas2Por", fields: [aprobado_2_por], references: [id])
  pagador    usuarios? @relation("SolicitudesPagadasPor", fields: [pagado_por], references: [id])

  adjuntos        adjuntos[]                  @relation("AdjuntosSolicitudPago")
  archivo_origen  adjuntos?                   @relation("SolicitudPagoArchivoOrigen", fields: [adjunto_archivo_origen_id], references: [id])
  detalles_nomina detalles_nomina_solicitud[]

  @@index([numero_solicitud])
  @@index([proyecto_base_id])
  @@index([fondo_id])
  @@index([centro_costo_id])
  @@index([beneficiario_id])
  @@index([proveedor_id])
  @@index([tipo_solicitud])
  @@index([estado_actual])
  @@index([medio_pago])
  @@index([categoria_gasto])
  @@index([categoria_reembolso])
  @@index([concepto_nomina])
  @@index([periodo_nomina])
  @@index([tipo_impuesto])
  @@index([periodo_impuesto])
  @@index([proyecto_base_id, centro_costo_id, beneficiario_id, concepto_nomina, periodo_nomina, estado_actual], map: "indice_solicitudes_nomina_individual_duplicados")
  @@index([creado_por])
  @@index([pagado_por])
  @@index([creado_en])
  @@index([pagado_en])
}

model adjuntos {
  id                String   @id @default(uuid())
  solicitud_pago_id String?
  nombre_archivo    String   @db.VarChar(255)
  ruta_archivo      String
  nombre_bucket     String   @db.VarChar(150)
  tipo_mime         String?  @db.VarChar(100)
  tamano_archivo    BigInt?
  subido_por        String?
  subido_en         DateTime @default(now())
  estado_ocr        String   @default("NO_PROCESADO") @db.VarChar(50)
  texto_ocr         String?
  json_ocr          Json?

  solicitud_pago             solicitudes_pago?  @relation("AdjuntosSolicitudPago", fields: [solicitud_pago_id], references: [id], onDelete: Cascade)
  solicitudes_archivo_origen solicitudes_pago[] @relation("SolicitudPagoArchivoOrigen")
  usuario_subio              usuarios?          @relation("AdjuntosSubidosPor", fields: [subido_por], references: [id])

  @@index([solicitud_pago_id])
  @@index([subido_por])
  @@index([estado_ocr])
  @@index([subido_en])
}

model detalles_nomina_solicitud {
  id                     String   @id @default(uuid())
  solicitud_pago_id      String
  numero_fila            Int
  beneficiario_id        String?
  tipo_documento         String
  numero_documento       String
  nombre_trabajador      String
  concepto_nomina        String
  medio_pago             String
  banco                  String?
  tipo_cuenta_bancaria   String?
  numero_cuenta_bancaria String?
  valor_bruto            Decimal  @db.Decimal(14, 2)
  valor_retenciones      Decimal  @default(0) @db.Decimal(14, 2)
  valor_descuentos       Decimal  @default(0) @db.Decimal(14, 2)
  valor_neto             Decimal  @db.Decimal(14, 2)
  estado_validacion      String   @default("VALIDO")
  errores_validacion     Json?
  creado_en              DateTime @default(now())
  actualizado_en         DateTime @updatedAt

  solicitud_pago solicitudes_pago    @relation(fields: [solicitud_pago_id], references: [id], onDelete: Cascade)
  beneficiario   beneficiarios_pago? @relation(fields: [beneficiario_id], references: [id])

  @@unique([solicitud_pago_id, numero_fila])
  @@index([solicitud_pago_id])
  @@index([beneficiario_id])
  @@index([tipo_documento, numero_documento])
  @@index([estado_validacion])
}
